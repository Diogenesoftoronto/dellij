{
  "name": "dellij",
  "version": "1.0.0",
  "description": "Zellij session manager with AI coding agent integration for parallel development workflows",
  "type": "module",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "main": "./src/index.ts",
  "files": ["src/**/*", "dellij", "plugin/**/*", "README.md"],
  "scripts": {
    "dev": "DELLIJ_DEV=true bun run src/index.ts",
    "start": "bun run src/index.ts",
