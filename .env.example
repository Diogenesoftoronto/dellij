# Convex Sync Configuration
# Your Convex Deployment URL (e.g., https://your-deployment-name.convex.cloud)
CONVEX_URL=
# Your Convex Auth Token (can be obtained from the dashboard for server-side pushes)
CONVEX_AUTH_TOKEN=

# GitHub OAuth Configuration (for mobile login)
# Register a new OAuth application in GitHub settings with redirect URI: dellij://auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
